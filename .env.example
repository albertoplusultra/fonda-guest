# Analytics — Umami (opcional)
# Si se definen ambas variables, se inyecta el script de seguimiento en producción.
VITE_ANALYTICS_ENDPOINT=https://tu-instancia-umami.example.com
VITE_ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Maps vía Frontend Forge (opcional)
# Solo necesario si se usa el componente MapView.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# OAuth — autenticación Manus (no necesario para deploy estático)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
